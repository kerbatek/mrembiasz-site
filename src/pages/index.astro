---
import "../styles/global.css";

const interests = [
  "Systems engineering",
  "Kubernetes",
  "Cloud infrastructure",
  "Networking",
  "Automation",
  "Self-hosting",
];

const technologyGroups = [
  {
    label: "Cloud",
    items: ["AWS", "S3", "CloudFront", "ACM", "Terraform"],
  },
  {
    label: "Platform",
    items: ["Linux", "Docker", "Kubernetes", "Helm", "Argo CD"],
  },
  {
    label: "Infrastructure",
    items: ["Proxmox", "MikroTik", "Ansible", "nginx", "PostgreSQL"],
  },
  {
    label: "Development",
    items: ["Python", "Bash", "YAML", "Flutter", "Dart"],
  },
];

const projects = [
  {
    title: "Portfolio",
    stack: "Astro / AWS / Terraform",
    description:
      "Static portfolio and cloud infrastructure practice using Astro, Terraform, private S3, CloudFront OAC, ACM TLS, and manual Cloudflare DNS.",
    href: "/projects/personal-site-aws-deployment/",
    repositoryHref: "https://github.com/kerbatek/mrembiasz-site",
  },
  {
    title: "Homelab Infrastructure Platform",
    stack: "Proxmox / MikroTik / Kubernetes",
    description:
      "Production-style lab for virtualization, routing, VLANs, Kubernetes workloads, service exposure, backups, and recovery practice.",
  },
  {
    title: "Kubernetes Learning Cluster",
    stack: "Kubernetes / Helm",
    description:
      "Hands-on practice with workloads, services, ingress, namespaces, storage, and cluster troubleshooting.",
  },
  {
    title: "CI/CD and Infrastructure Automation Practice",
    stack: "Terraform / Ansible",
    description:
      "Infrastructure and deployment automation using Git, GitLab CI, Terraform, Ansible, YAML, and Bash.",
  },
];

const learningItems = [
  {
    title: "AWS SAA-C03",
    description:
      "Preparing with focus on IAM, networking, compute, storage, high availability, and cost-aware architecture.",
  },
  {
    title: "CCNA: Introduction to Networks",
    description:
      "Completed Cisco module covering switching, routing basics, IP addressing, subnetting, and troubleshooting.",
  },
];

const socialLinks = [
  {
    label: "Email",
    href: "mailto:mateusz@mrembiasz.pl",
    paths: [
      "M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z",
      "M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z",
    ],
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/mateusz-rembiasz/",
    paths: [
      "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
    ],
  },
  {
    label: "GitLab",
    href: "https://gitlab.mrembiasz.pl/kerbatek",
    paths: [
      "m22.65 14.39-1.35-4.15-2.67-8.22a.46.46 0 0 0-.88 0l-2.67 8.22H8.92L6.25 2.02a.46.46 0 0 0-.88 0L2.7 10.24l-1.35 4.15a.92.92 0 0 0 .33 1.03L12 22.93l10.32-7.51a.92.92 0 0 0 .33-1.03Z",
    ],
  },
  {
    label: "GitHub",
    href: "https://github.com/kerbatek",
    paths: [
      "M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z",
