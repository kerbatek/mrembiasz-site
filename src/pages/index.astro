---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Personal landing page for Mateusz Rembiasz."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Mateusz Rembiasz</title>
  </head>
  <body>
    <main class="container index-page">
      <nav class="nav" aria-label="Primary navigation">
        <a href="/" aria-current="page">Home</a>
        <a href="/projects/personal-site-aws-deployment/">
          Portfolio architecture
        </a>
      </nav>

      <h1 class="name">Mateusz Rembiasz</h1>
      <p class="status">Cloud &amp; DevOps</p>
      <p class="bio">
        Cloud and infrastructure-focused engineer building practical experience
        across AWS, Kubernetes, networking, automation, and self-hosted systems.
      </p>

      <section class="section" aria-labelledby="interests-title">
        <p id="interests-title" class="section-label">Interests</p>
        <div class="tags">
          {interests.map((item) => <span class="tag">{item}</span>)}
        </div>
      </section>

      <section class="section" aria-labelledby="learning-title">
        <p id="learning-title" class="section-label">Learning</p>
        <div class="learning-list">
          {
            learningItems.map((item) => (
              <article class="learning-item">
                <h2>{item.title}</h2>
                <p>{item.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" aria-labelledby="projects-title">
        <p id="projects-title" class="section-label">Projects</p>
        <div class="projects">
          {
            projects.map((project) => (
              <article class="project">
                <div class="project-header">
                  <h2>
                    {
                      project.href ? (
                        <a href={project.href}>{project.title}</a>
                      ) : (
                        project.title
                      )
                    }
                  </h2>
                  <span>{project.stack}</span>
                </div>
                <p>{project.description}</p>
                <div class="project-links">
                  {
                    project.repositoryHref && (
                      <a
                        class="project-link"
                        href={project.repositoryHref}
                        rel="noopener noreferrer"
                        target="_blank"
                      >
                        GitHub
                      </a>
                    )
                  }
                  {
                    project.href && (
                      <a class="project-link" href={project.href}>
                        Read case study
                      </a>
                    )
                  }
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" aria-labelledby="tech-title">
        <p id="tech-title" class="section-label">Technologies</p>
        <div class="technology-groups">
          {
            technologyGroups.map((group) => (
              <div class="technology-group">
                <h2>{group.label}</h2>
                <p>{group.items.join(" / ")}</p>
              </div>
            ))
          }
        </div>
      </section>

      <section class="section" aria-labelledby="languages-title">
        <p id="languages-title" class="section-label">Languages</p>
        <p class="body-copy">Polish: Native / English: C1</p>
      </section>

      <p class="section-label">Contact</p>
      <div class="social" aria-label="Social links">
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              rel={link.href.startsWith("https://") ? "noopener noreferrer" : undefined}
              target={link.href.startsWith("https://") ? "_blank" : undefined}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                {link.paths.map((path) => <path d={path} />)}
              </svg>
              {link.label}
            </a>
          ))
        }
      </div>
    </main>
  </body>
</html>
